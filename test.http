###############################################################################
# test.http — Livrable de test gestion_paiement (REST Client VSCode)
# Mois courant = 2026-06. Requetes mutent l'etat : jouer de haut en bas.
###############################################################################
@walletHost = http://localhost:8080
@paymentHost = http://localhost:8081

###############################################################################
# PAYMENT-SERVICE (8081) — tests directs
###############################################################################

### 1) Impayees mois courant wallet 3 (tous) — attendu: 200
GET {{paymentHost}}/api/factures/WLT-0000003/current

### 2) Impayees mois courant wallet 3 (WOYAFAL) — attendu: 200
GET {{paymentHost}}/api/factures/WLT-0000003/current?unite=WOYAFAL

### 3) Impayees mois courant wallet 3 (ISM) — attendu: 200
GET {{paymentHost}}/api/factures/WLT-0000003/current?unite=ISM

### 4) Impayees periode 2026-05-01 -> 2026-07-01 wallet 3 — attendu: 200
GET {{paymentHost}}/api/factures/WLT-0000003/periode?debut=2026-05-01&fin=2026-07-01

### 5) Pay-current ISM montant errone — attendu: 400
POST {{paymentHost}}/api/factures/pay-current
Content-Type: application/json

{
  "walletCode": "WLT-0000003",
  "service": "ISM",
  "amount": 1
}

### 6) Pay-current ISM mois courant — attendu: 200
POST {{paymentHost}}/api/factures/pay-current
Content-Type: application/json

{
  "walletCode": "WLT-0000003",
  "service": "ISM",
  "amount": 150000
}

### 7) Pay-by-references ISM wallet 3 — attendu: 200
POST {{paymentHost}}/api/factures/pay-by-references
Content-Type: application/json

{
  "walletCode": "WLT-0000003",
  "service": "ISM",
  "references": ["FAC-ISM-3-1", "FAC-ISM-3-3"]
}

### 8) Pay-by-references reference deja payee — attendu: 409
POST {{paymentHost}}/api/factures/pay-by-references
Content-Type: application/json

{
  "walletCode": "WLT-0000003",
  "service": "ISM",
  "references": ["FAC-ISM-3-1"]
}

### 9) Pay-by-references reference d'une autre wallet — attendu: 400
POST {{paymentHost}}/api/factures/pay-by-references
Content-Type: application/json

{
  "walletCode": "WLT-0000003",
  "service": "ISM",
  "references": ["FAC-ISM-1-1"]
}

### 10) Pay-by-references reference inconnue — attendu: 404
POST {{paymentHost}}/api/factures/pay-by-references
Content-Type: application/json

{
  "walletCode": "WLT-0000003",
  "service": "ISM",
  "references": ["FAC-ISM-3-999"]
}

###############################################################################
# PROXY FACTURES (badwallet 8080 -> payment-service 8081)
# Pattern Proxy : badwallet relaie ces requetes vers payment-service par un
# vrai appel HTTP. LES DEUX SERVICES DOIVENT TOURNER (8080 ET 8081).
###############################################################################

### P1) Proxy current (tous) wallet 3 — attendu: 200, factures relayees de 8081
GET {{walletHost}}/api/external/factures/WLT-0000003/current

### P2) Proxy current filtre WOYAFAL wallet 3 — attendu: 200, relai filtre
GET {{walletHost}}/api/external/factures/WLT-0000003/current?unite=WOYAFAL

### P3) Proxy periode 2026-05-01 -> 2026-07-01 wallet 3 — attendu: 200, relai
GET {{walletHost}}/api/external/factures/WLT-0000003/periode?debut=2026-05-01&fin=2026-07-01

###############################################################################
# BADWALLET-API (8080) — Wallets
###############################################################################

### 1) Creation nominale d'une wallet — attendu: 201
POST {{walletHost}}/api/wallets
Content-Type: application/json

{
  "phoneNumber": "+221779998877",
  "email": "testclient@gmail.com",
  "initialBalance": 25000,
  "code": "WLT-TEST001",
  "currency": "XOF"
}

### 2) Re-creation avec le meme code WLT-TEST001 — attendu: 409
POST {{walletHost}}/api/wallets
Content-Type: application/json

{
  "phoneNumber": "+221779998877",
  "email": "testclient@gmail.com",
  "initialBalance": 25000,
  "code": "WLT-TEST001",
  "currency": "XOF"
}

### 3) Creation avec body invalide (initialBalance negatif) — attendu: 400
POST {{walletHost}}/api/wallets
Content-Type: application/json

{
  "phoneNumber": "",
  "email": "testclient@gmail.com",
  "initialBalance": -5,
  "code": "WLT-TEST002",
  "currency": "XOF"
}

### Lister les wallets (page 0, taille 10) — attendu: 200
GET {{walletHost}}/api/wallets?page=0&size=10

# NOTE : les 3 requetes ci-dessous supposent que la wallet +221779998877 existe
# (creee par la requete de creation nominale plus haut dans cette section).

### Consulter une wallet par telephone — attendu: 200
GET {{walletHost}}/api/wallets/+221779998877

### Consulter le solde d'une wallet — attendu: 200
GET {{walletHost}}/api/wallets/+221779998877/balance

### Consulter une wallet inexistante — attendu: 404
GET {{walletHost}}/api/wallets/+221700000000

###############################################################################
# BADWALLET-API (8080) — Depots
###############################################################################

# NOTE : les depots ci-dessous visent la wallet d'id 1, soit celle creee par la
# requete de creation nominale plus haut dans cette section (sur base fraiche).

### Depot par carte sur wallet id 1 — attendu: 200
POST {{walletHost}}/api/wallets/1/deposit
Content-Type: application/json

{ "amount": 50000.00, "paymentMethod": "CREDIT_CARD" }

### Depot depuis une autre wallet (libelle) sur wallet id 1 — attendu: 200
POST {{walletHost}}/api/wallets/1/deposit
Content-Type: application/json

{ "amount": 10000.00, "paymentMethod": "WALLET_TARGET" }

### Depot sur wallet inexistante — attendu: 404
POST {{walletHost}}/api/wallets/999/deposit
Content-Type: application/json

{ "amount": 5000.00, "paymentMethod": "CREDIT_CARD" }

###############################################################################
# BADWALLET-API (8080) — Retraits
###############################################################################

# NOTE : les retraits ci-dessous supposent que la wallet +221779998877 existe
# avec du solde (creee par la requete de creation nominale plus haut).

### Retrait normal (frais 1%) — attendu: 200
POST {{walletHost}}/api/wallets/withdraw
Content-Type: application/json

{ "phoneNumber": "+221779998877", "amount": 10000.00 }

### Retrait montant superieur au solde — attendu: 400
POST {{walletHost}}/api/wallets/withdraw
Content-Type: application/json

{ "phoneNumber": "+221779998877", "amount": 99999999.00 }

###############################################################################
# BADWALLET-API (8080) — Transferts
###############################################################################

# NOTE : les transferts supposent deux wallets existantes : l'emettrice
# +221779998877 (creee plus haut, solde 25000) et la receptrice +221770000002
# (creee ci-dessous).

### Creation de la wallet receptrice +221770000002 — attendu: 201
POST {{walletHost}}/api/wallets
Content-Type: application/json

{
  "phoneNumber": "+221770000002",
  "email": "receveur@gmail.com",
  "initialBalance": 0,
  "code": "WLT-TEST002",
  "currency": "XOF"
}

### Transfert entre deux wallets — attendu: 200
POST {{walletHost}}/api/wallets/transfer
Content-Type: application/json

{ "senderPhone": "+221779998877", "receiverPhone": "+221770000002", "amount": 2000.00 }

### Transfert vers soi-meme — attendu: 400
POST {{walletHost}}/api/wallets/transfer
Content-Type: application/json

{ "senderPhone": "+221779998877", "receiverPhone": "+221779998877", "amount": 1000.00 }

### Transfert montant superieur au solde — attendu: 400
POST {{walletHost}}/api/wallets/transfer
Content-Type: application/json

{ "senderPhone": "+221779998877", "receiverPhone": "+221770000002", "amount": 99999999.00 }

###############################################################################
# BADWALLET-API (8080) — Historique
###############################################################################

# Section auto-suffisante : cree sa propre wallet +221770000050, fait 1 depot et
# 1 retrait dessus, puis liste son historique (du plus recent au plus ancien).
# L'id renvoye a la creation est reutilise pour le depot (endpoint par id).

### Creation wallet pour historique — attendu: 201
# @name histWallet
POST {{walletHost}}/api/wallets
Content-Type: application/json

{
  "phoneNumber": "+221770000050",
  "email": "historique@gmail.com",
  "initialBalance": 25000,
  "code": "WLT-HIST050",
  "currency": "XOF"
}

### Depot sur cette wallet — attendu: 200
POST {{walletHost}}/api/wallets/{{histWallet.response.body.$.body.id}}/deposit
Content-Type: application/json

{ "amount": 15000.00, "paymentMethod": "CREDIT_CARD" }

### Retrait sur cette wallet — attendu: 200
POST {{walletHost}}/api/wallets/withdraw
Content-Type: application/json

{ "phoneNumber": "+221770000050", "amount": 5000.00 }

### Historique des transactions — attendu: 200 (DEPOT + RETRAIT listes)
GET {{walletHost}}/api/wallets/+221770000050/transactions

### Historique wallet inexistante — attendu: 404
GET {{walletHost}}/api/wallets/+221700000000/transactions

###############################################################################
# PAIEMENT FACTURES (badwallet 8080, debite wallet + relaie payment-service 8081)
# badwallet DEBITE la wallet PUIS marque les factures payees cote payment-service
# par un appel HTTP. Debit-avant-appel + @Transactional => tout-ou-rien : si
# payment-service refuse ou est injoignable, le debit est annule (rollback).
#
# PREREQUIS : LES DEUX SERVICES DOIVENT TOURNER (8080 ET 8081).
# Rejouer payment-service (base H2 en memoire, reseedee au demarrage) avant cette
# section pour que les factures ISM de WLT-0000003 soient impayees (le bloc direct
# pay-current/pay-by-references plus haut les aurait deja payees).
###############################################################################

### PF1) Creer la wallet WLT-0000003 cote badwallet (phone +221770000003, solde 500000)
# Le CODE doit valoir WLT-0000003 : c'est lui qu'attend payment-service.
# attendu: 201 (ou 409 si la wallet existe deja)
POST {{walletHost}}/api/wallets
Content-Type: application/json

{
  "phoneNumber": "+221770000003",
  "email": "client3@gmail.com",
  "initialBalance": 500000,
  "code": "WLT-0000003",
  "currency": "XOF"
}

### PF2) Solde initial — attendu: 200, balance 500000
GET {{walletHost}}/api/wallets/+221770000003/balance

### PF3) /pay : paie la facture ISM du mois courant (150000) — attendu: 200, solde -> 350000
# Debite 150000 puis relaie payment-service pay-current (FAC-ISM-3-6 marquee payee).
POST {{walletHost}}/api/wallets/pay
Content-Type: application/json

{
  "phoneNumber": "+221770000003",
  "serviceName": "ISM",
  "amount": 150000
}

### PF4) Verifier cote payment-service : ISM du mois courant n'apparait plus — attendu: 200, body []
GET {{paymentHost}}/api/factures/WLT-0000003/current?unite=ISM

### PF5) /pay-factures : paie FAC-ISM-3-1 (150000) — attendu: 200, solde -> 200000
# Total calcule via payment-service (factures impayees) puis debit puis relai pay-by-references.
POST {{walletHost}}/api/wallets/pay-factures
Content-Type: application/json

{
  "phoneNumber": "+221770000003",
  "serviceName": "ISM",
  "factureReferences": ["FAC-ISM-3-1"]
}

### PF6) Solde apres les deux paiements — attendu: 200, balance 200000
GET {{walletHost}}/api/wallets/+221770000003/balance

### PF7) Historique : 2 transactions PAIEMENT de 150000 — attendu: 200
GET {{walletHost}}/api/wallets/+221770000003/transactions

### PF8) ERREUR solde insuffisant — attendu: 400, AUCUN debit (solde inchange)
# Le controle de solde precede tout appel distant : rien n'est debite.
POST {{walletHost}}/api/wallets/pay
Content-Type: application/json

{
  "phoneNumber": "+221770000003",
  "serviceName": "WOYAFAL",
  "amount": 999999999
}

### PF9) ERREUR reference inconnue/deja payee — attendu: 409, AUCUN debit (rejet AVANT debit)
POST {{walletHost}}/api/wallets/pay-factures
Content-Type: application/json

{
  "phoneNumber": "+221770000003",
  "serviceName": "ISM",
  "factureReferences": ["FAC-ISM-3-999"]
}

### PF10) ERREUR payment-service injoignable — attendu: 503, solde INCHANGE (rollback du debit)
# Pour reproduire : ARRETER payment-service (8081), puis lancer cette requete sur une
# facture impayee (ex. WOYAFAL mois courant). Le debit est annule par le @Transactional.
POST {{walletHost}}/api/wallets/pay
Content-Type: application/json

{
  "phoneNumber": "+221770000003",
  "serviceName": "WOYAFAL",
  "amount": 15000
}
